# ─── LLM Provider 配置 ──────────────────────────────────
# 可选值：deepseek | claude | openai | custom
# 默认：deepseek（最便宜，中文好，推荐）
LLM_PROVIDER=deepseek

# ─── API Key ───────────────────────────────────────────
# DeepSeek：https://platform.deepseek.com → API Keys
# 新用户注册送 500 万 tokens 免费额度，够跑几千次测试
LLM_API_KEY=sk-your-deepseek-key

# ─── 如果要切换到 Claude ────────────────────────────────
# 把上面两行改为：
# LLM_PROVIDER=claude
# LLM_API_KEY=sk-ant-your-claude-key

# ─── 数据库 ───────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── 部署模式（上线后启用）─────────────────────────────
# 设为 true 后，用户必须先填入自己的 API Key 才能使用
# 避免你的个人 Key 被大量消耗
# REQUIRE_USER_KEY=true

# ─── 高级选项（一般不用改）────────────────────────────────
# LLM_MODEL=deepseek-chat          # 模型名
# LLM_BASE_URL=https://api.deepseek.com  # API 地址
